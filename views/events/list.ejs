<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main>
    <section class="page-header">
        <div class="container">
            <h1>Browse Events</h1>

            <form action="/events" method="GET" class="search-form">
                <input
                    type="text"
                    name="search"
                    value="<%= searchTerm %>"
                    placeholder="Search events..."
                    class="search-input"
                >
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Search
                </button>
            </form>
        </div>
    </section>

    <section class="events-section">
        <div class="container">
            <div class="sidebar-layout">
                <!-- Sidebar -->
                <aside class="sidebar">
                    <h3>Categories</h3>
                    <ul class="category-list">
                        <li>
                            <a href="/events" class="<%= !selectedCategory ? 'active' : '' %>">
                                All Events
                            </a>
                        </li>
                        <% categories.forEach(category => { %>
                            <li>
                                <a href="/events/category/<%= category.slug %>"
                                   class="<%= selectedCategory === category.slug ? 'active' : '' %>">
                                    <%= category.name %>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                </aside>

                <!-- Main Content -->
                <div class="main-content">
                    <% if (events.length === 0) { %>
                        <div class="no-results">
                            <i class="fas fa-search"></i>
                            <h3>No events found</h3>
                            <p>Try adjusting your search or browse all events</p>
                            <a href="/events" class="btn btn-primary">View All Events</a>
                        </div>
                    <% } else { %>
                        <div class="results-header">
                            <p>Found <%= events.length %> event<%= events.length !== 1 ? 's' : '' %></p>
                        </div>

                        <div class="event-grid">
                            <% events.forEach(event => { %>
                                <div class="event-card">
                                    <div class="event-image">
                                        <img src="<%= event.image_url || '/images/default-event.jpg' %>"
                                             alt="<%= event.title %>">
                                        <span class="event-category"><%= event.category_name %></span>
                                    </div>
                                    <div class="event-info">
                                        <h3><%= event.title %></h3>
                                        <p class="event-venue">
                                            <i class="fas fa-map-marker-alt"></i>
                                            <%= event.venue_name %>
                                        </p>
                                        <p class="event-date">
                                            <i class="fas fa-calendar"></i>
                                            <%= new Date(event.event_date).toLocaleDateString('en-US', {
                                                weekday: 'short',
                                                year: 'numeric',
                                                month: 'short',
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            }) %>
                                        </p>
                                        <div class="event-footer">
                                            <div class="event-rating">
                                                <% if (event.rating_count > 0) { %>
                                                    <i class="fas fa-star"></i>
                                                    <%= parseFloat(event.avg_rating).toFixed(1) %>
                                                    (<%= event.rating_count %>)
                                                <% } else { %>
                                                    <span class="no-rating">No ratings yet</span>
                                                <% } %>
                                            </div>
                                            <div class="event-price">
                                                From $<%= parseFloat(event.base_price).toFixed(2) %>
                                            </div>
                                        </div>
                                        <div class="event-tickets">
                                            <span class="tickets-available">
                                                <%= event.available_tickets %> tickets available
                                            </span>
                                        </div>
                                        <a href="/events/<%= event.id %>" class="btn btn-block btn-primary">
                                            View Details
                                        </a>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
