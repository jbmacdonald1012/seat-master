<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main>
    <section class="event-detail">
        <div class="container">
            <div class="event-header">
                <div class="event-image-large">
                    <img src="<%= event.image_url || '/images/default-event.jpg' %>"
                         alt="<%= event.title %>">
                </div>
                <div class="event-info-main">
                    <span class="category-badge"><%= event.category_name %></span>
                    <h1><%= event.title %></h1>

                    <div class="event-meta">
                        <div class="meta-item">
                            <i class="fas fa-calendar"></i>
                            <div>
                                <strong>Date & Time</strong>
                                <p><%= new Date(event.event_date).toLocaleDateString('en-US', {
                                    weekday: 'long',
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric'
                                }) %></p>
                                <p><%= new Date(event.event_date).toLocaleTimeString('en-US', {
                                    hour: '2-digit',
                                    minute: '2-digit'
                                }) %></p>
                            </div>
                        </div>

                        <div class="meta-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <div>
                                <strong>Venue</strong>
                                <p><%= event.venue_name %></p>
                                <p class="text-muted"><%= event.venue_address %></p>
                                <p class="text-muted"><%= event.city %>, <%= event.state %></p>
                            </div>
                        </div>

                        <div class="meta-item">
                            <i class="fas fa-ticket-alt"></i>
                            <div>
                                <strong>Availability</strong>
                                <p><%= event.available_tickets %> / <%= event.total_tickets %> tickets available</p>
                            </div>
                        </div>

                        <div class="meta-item">
                            <i class="fas fa-dollar-sign"></i>
                            <div>
                                <strong>Starting Price</strong>
                                <p class="price-large">$<%= parseFloat(event.base_price).toFixed(2) %></p>
                            </div>
                        </div>
                    </div>

                    <div class="event-actions">
                        <% if (event.available_tickets > 0) { %>
                            <button onclick="showTicketSelector()" class="btn btn-primary btn-large">
                                <i class="fas fa-shopping-cart"></i>
                                Get Tickets
                            </button>
                        <% } else { %>
                            <button class="btn btn-large" disabled>
                                Sold Out
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Ticket Selector Modal -->
            <% if (event.available_tickets > 0) { %>
                <div id="ticketModal" class="modal" style="display: none;">
                    <div class="modal-content">
                        <span class="close" onclick="closeTicketSelector()">&times;</span>
                        <h2>Select Your Tickets</h2>

                        <form id="ticketForm">
                            <div class="tickets-list">
                                <%
                                const sections = {};
                                availableTickets.forEach(ticket => {
                                    if (!sections[ticket.section]) {
                                        sections[ticket.section] = [];
                                    }
                                    sections[ticket.section].push(ticket);
                                });

                                Object.keys(sections).forEach(section => {
                                %>
                                    <div class="ticket-section">
                                        <h3><%= section %></h3>
                                        <div class="ticket-items">
                                            <% sections[section].slice(0, 10).forEach(ticket => { %>
                                                <label class="ticket-item">
                                                    <input
                                                        type="checkbox"
                                                        name="tickets"
                                                        value="<%= ticket.id %>"
                                                        data-price="<%= ticket.price %>"
                                                        onchange="updateTotal()"
                                                    >
                                                    <span class="ticket-details">
                                                        <strong>Row <%= ticket.row_number %>, Seat <%= ticket.seat_number %></strong>
                                                        <span class="ticket-price">$<%= parseFloat(ticket.price).toFixed(2) %></span>
                                                    </span>
                                                </label>
                                            <% }) %>
                                        </div>
                                        <% if (sections[section].length > 10) { %>
                                            <p class="text-muted">+<%= sections[section].length - 10 %> more available</p>
                                        <% } %>
                                    </div>
                                <% }) %>
                            </div>

                            <div class="checkout-summary">
                                <div class="summary-row">
                                    <span>Selected Tickets:</span>
                                    <span id="ticketCount">0</span>
                                </div>
                                <div class="summary-row total">
                                    <span>Total:</span>
                                    <span id="totalPrice">$0.00</span>
                                </div>
                            </div>

                            <button type="button" onclick="proceedToCheckout()" class="btn btn-primary btn-block">
                                Proceed to Checkout
                            </button>
                        </form>
                    </div>
                </div>
            <% } %>

            <!-- Tabs -->
            <div class="event-tabs">
                <div class="tab-buttons">
                    <button class="tab-btn active" onclick="switchTab('description')">Description</button>
                    <button class="tab-btn" onclick="switchTab('reviews')">Reviews & Ratings</button>
                </div>

                <div id="descriptionTab" class="tab-content active">
                    <div class="description-content">
                        <h2>About This Event</h2>
                        <p><%= event.description %></p>
                    </div>
                </div>

                <div id="reviewsTab" class="tab-content">
                    <!-- Rating Summary -->
                    <div class="rating-summary">
                        <div class="rating-score">
                            <h2><%= parseFloat(event.avg_rating || 0).toFixed(1) %></h2>
                            <div class="stars">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <i class="fas fa-star <%= i <= Math.round(event.avg_rating || 0) ? 'filled' : '' %>"></i>
                                <% } %>
                            </div>
                            <p><%= event.rating_count %> rating<%= event.rating_count !== 1 ? 's' : '' %></p>
                        </div>

                        <% if (isAuthenticated) { %>
                            <div class="user-rating">
                                <h3>Your Rating</h3>
                                <div class="rating-stars" id="userRatingStars">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <i class="far fa-star rating-star"
                                           data-rating="<%= i %>"
                                           onclick="submitRating(<%= i %>)"></i>
                                    <% } %>
                                </div>
                                <% if (userRating) { %>
                                    <script>
                                        document.addEventListener('DOMContentLoaded', () => {
                                            highlightStars(<%= userRating.rating %>);
                                        });
                                    </script>
                                <% } %>
                            </div>
                        <% } %>
                    </div>

                    <!-- Comments Section -->
                    <div class="comments-section">
                        <h3>Comments (<%= comments.length %>)</h3>

                        <% if (isAuthenticated) { %>
                            <form id="commentForm" class="comment-form">
                                <textarea
                                    name="comment_text"
                                    placeholder="Share your thoughts about this event..."
                                    rows="3"
                                    required
                                ></textarea>
                                <button type="submit" class="btn btn-primary">Post Comment</button>
                            </form>
                        <% } else { %>
                            <p class="auth-prompt">
                                <a href="/auth/login?returnTo=/events/<%= event.id %>">Login</a> to leave a comment
                            </p>
                        <% } %>

                        <div id="commentsList" class="comments-list">
                            <% if (comments.length === 0) { %>
                                <p class="no-comments">No comments yet. Be the first to share your thoughts!</p>
                            <% } else { %>
                                <% comments.forEach(comment => { %>
                                    <div class="comment" data-comment-id="<%= comment.id %>">
                                        <div class="comment-header">
                                            <strong><%= comment.full_name || comment.username %></strong>
                                            <span class="comment-date">
                                                <%= new Date(comment.created_at).toLocaleDateString() %>
                                            </span>
                                        </div>
                                        <p class="comment-text"><%= comment.comment_text %></p>
                                        <% if (isAuthenticated && (user.id === comment.user_id || user.role === 'admin' || user.role === 'employee')) { %>
                                            <div class="comment-actions">
                                                <% if (user.id === comment.user_id) { %>
                                                    <button onclick="editComment(<%= comment.id %>)" class="btn-text">Edit</button>
                                                <% } %>
                                                <button onclick="deleteComment(<%= comment.id %>)" class="btn-text text-danger">Delete</button>
                                            </div>
                                        <% } %>
                                    </div>
                                <% }) %>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<script>
const eventId = <%= event.id %>;
const isAuthenticated = <%= isAuthenticated %>;

function showTicketSelector() {
    document.getElementById('ticketModal').style.display = 'block';
}

function closeTicketSelector() {
    document.getElementById('ticketModal').style.display = 'none';
}

function updateTotal() {
    const checkboxes = document.querySelectorAll('input[name="tickets"]:checked');
    let total = 0;
    checkboxes.forEach(cb => {
        total += parseFloat(cb.dataset.price);
    });
    document.getElementById('ticketCount').textContent = checkboxes.length;
    document.getElementById('totalPrice').textContent = '$' + total.toFixed(2);
}

function proceedToCheckout() {
    const checkboxes = document.querySelectorAll('input[name="tickets"]:checked');
    if (checkboxes.length === 0) {
        alert('Please select at least one ticket');
        return;
    }
    const ticketIds = Array.from(checkboxes).map(cb => cb.value).join(',');
    window.location.href = `/purchases/checkout/${eventId}?tickets=${ticketIds}`;
}

function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

    if (tab === 'description') {
        document.querySelector('[onclick="switchTab(\'description\')"]').classList.add('active');
        document.getElementById('descriptionTab').classList.add('active');
    } else {
        document.querySelector('[onclick="switchTab(\'reviews\')"]').classList.add('active');
        document.getElementById('reviewsTab').classList.add('active');
    }
}

function highlightStars(rating) {
    const stars = document.querySelectorAll('.rating-star');
    stars.forEach((star, index) => {
        if (index < rating) {
            star.classList.remove('far');
            star.classList.add('fas', 'filled');
        } else {
            star.classList.remove('fas', 'filled');
            star.classList.add('far');
        }
    });
}

async function submitRating(rating) {
    if (!isAuthenticated) {
        window.location.href = '/auth/login?returnTo=/events/' + eventId;
        return;
    }

    try {
        const response = await fetch('/api/ratings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_id: eventId, rating })
        });

        const data = await response.json();
        if (data.success) {
            highlightStars(rating);
            location.reload();
        }
    } catch (error) {
        console.error('Error submitting rating:', error);
        alert('Failed to submit rating');
    }
}

if (isAuthenticated) {
    document.getElementById('commentForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(e.target);
        const commentText = formData.get('comment_text');

        try {
            const response = await fetch('/api/comments', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    event_id: eventId,
                    comment_text: commentText
                })
            });

            const data = await response.json();
            if (data.success) {
                location.reload();
            }
        } catch (error) {
            console.error('Error posting comment:', error);
            alert('Failed to post comment');
        }
    });
}

function editComment(commentId) {
    const commentDiv = document.querySelector(`[data-comment-id="${commentId}"]`);
    if (!commentDiv) return;
    const textEl = commentDiv.querySelector('.comment-text');
    const currentText = textEl.textContent.trim();

    textEl.innerHTML = `
        <textarea class="form-control" rows="2" id="editText_${commentId}">${currentText}</textarea>
        <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem;">
            <button onclick="saveComment(${commentId})" class="btn btn-primary" style="padding: 0.3rem 0.75rem; font-size: 0.85rem;">Save</button>
            <button onclick="cancelEdit(${commentId}, \`${currentText.replace(/`/g, '\\`')}\`)" class="btn" style="padding: 0.3rem 0.75rem; font-size: 0.85rem; background: #666;">Cancel</button>
        </div>`;
}

function cancelEdit(commentId, originalText) {
    const commentDiv = document.querySelector(`[data-comment-id="${commentId}"]`);
    if (!commentDiv) return;
    commentDiv.querySelector('.comment-text').innerHTML = originalText;
}

async function saveComment(commentId) {
    const textarea = document.getElementById(`editText_${commentId}`);
    if (!textarea) return;
    const newText = textarea.value.trim();
    if (!newText) return;

    try {
        const response = await fetch(`/api/comments/${commentId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ comment_text: newText })
        });
        const data = await response.json();
        if (data.success) location.reload();
    } catch (error) {
        console.error('Error editing comment:', error);
        alert('Failed to edit comment');
    }
}

async function deleteComment(commentId) {
    if (!confirm('Are you sure you want to delete this comment?')) return;

    try {
        const response = await fetch(`/api/comments/${commentId}`, {
            method: 'DELETE'
        });

        const data = await response.json();
        if (data.success) {
            location.reload();
        }
    } catch (error) {
        console.error('Error deleting comment:', error);
        alert('Failed to delete comment');
    }
}
</script>

<%- include('../partials/footer') %>
