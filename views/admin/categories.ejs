<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main>
    <section class="page-header">
        <div class="container">
            <a href="/admin" class="admin-back-link">
                <i class="fas fa-arrow-left"></i> Admin Dashboard
            </a>
            <h1>Manage Categories</h1>
            <p>Add or remove event categories</p>
        </div>
    </section>

    <section class="admin-section">
        <div class="container">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start;">
                <!-- Category List -->
                <div>
                    <h2>Current Categories</h2>
                    <% if (categories.length === 0) { %>
                        <p class="text-muted">No categories yet.</p>
                    <% } else { %>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Slug</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% categories.forEach(cat => { %>
                                    <tr>
                                        <td><%= cat.name %></td>
                                        <td><code><%= cat.slug %></code></td>
                                        <td>
                                            <form action="/admin/categories/<%= cat.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this category?')">
                                                <button type="submit" class="btn-text text-danger">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>

                <!-- Add Category Form -->
                <div class="content-box">
                    <h2>Add Category</h2>
                    <form action="/admin/categories" method="POST" class="auth-form">
                        <div class="form-group">
                            <label for="name">Category Name</label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                class="form-control"
                                placeholder="e.g. Concerts"
                            >
                        </div>
                        <div class="form-group">
                            <label for="slug">Slug</label>
                            <input
                                type="text"
                                id="slug"
                                name="slug"
                                required
                                class="form-control"
                                placeholder="e.g. concerts"
                            >
                            <small>Lowercase letters and hyphens only</small>
                        </div>
                        <button type="submit" class="btn btn-primary">Add Category</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
